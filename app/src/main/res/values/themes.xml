<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AudioBookPlayer" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
    </style>

    <style name="Theme.AudioBookPlayer.Player" parent="Theme.AudioBookPlayer">
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- Экран загрузки: чёрный фон + белая пиковая масть по центру -->
    <style name="Theme.AudioBookPlayer.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_spade</item>
        <item name="postSplashScreenTheme">@style/Theme.AudioBookPlayer</item>
    </style>
</resources>
