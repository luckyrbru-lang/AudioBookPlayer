<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:paddingHorizontal="24dp">

    <!-- Верхняя панель -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/round_ripple_bg"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/text_primary"
        android:contentDescription="Назад"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnBookmarks"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/round_ripple_bg"
        android:src="@android:drawable/ic_menu_agenda"
        app:tint="@color/accent_yellow"
        android:contentDescription="Закладки"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Обложка -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/coverCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/bg_surface"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.68"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <ImageView
            android:id="@+id/coverImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Обложка книги" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Название / автор -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Название книги"
        app:layout_constraintTop_toBottomOf="@id/coverCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:text="Автор"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Тонкий прогресс-бар без крупного "пипса" -->
    <SeekBar
        android:id="@+id/progressSeekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:progressTint="@color/accent_yellow"
        android:progressBackgroundTint="@color/progress_track"
        android:thumbTint="@color/accent_yellow"
        android:maxHeight="4dp"
        android:progressDrawable="@android:drawable/progress_horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvAuthor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvPosition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:text="0:00"
        app:layout_constraintTop_toBottomOf="@id/progressSeekBar"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:text="0:00"
        app:layout_constraintTop_toBottomOf="@id/progressSeekBar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Управление воспроизведением -->
    <LinearLayout
        android:id="@+id/controlsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvPosition"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnSkipBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/round_ripple_bg"
            android:src="@android:drawable/ic_media_rew"
            app:tint="@color/text_primary"
            android:contentDescription="Назад 15 сек" />

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="28dp"
            android:background="@drawable/play_button_bg"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/bg_primary"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/btnSkipForward"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/round_ripple_bg"
            android:src="@android:drawable/ic_media_ff"
            app:tint="@color/text_primary"
            android:contentDescription="Вперёд 30 сек" />
    </LinearLayout>

    <!-- Нижние капсулы: скорость / таймер сна / закладка -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/controlsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btnSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/capsule_bg"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:text="♦︎ 1.0x"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnSleepTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/capsule_bg"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:text="♣︎ Таймер сна"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnAddBookmark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/capsule_bg"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:text="♠︎"
            android:textColor="@color/suit_glyph"
            android:textSize="16sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
